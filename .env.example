# ============================================================================
# AUGC Pipeline - variables de entorno
# Copiá este archivo a .env.local y ajustá los valores.
# NO pongas API keys ni service accounts: la autenticacion es por ADC (gcloud).
# ============================================================================

# Modo de proveedor:
#   mock   -> genera placeholders localmente, sin credenciales ni cuota (probar pipeline completo)
#   vertex -> llamadas reales a Vertex AI (requiere ADC configurado)
PROVIDER_MODE=mock

# --- Google Cloud / Vertex AI (solo necesario con PROVIDER_MODE=vertex) ---
# La identidad se resuelve por Application Default Credentials (ADC):
#   gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Modelos por defecto (tambien seleccionables desde la UI por proyecto) ---
# Chat:  gemini-3.1-pro-preview | gemini-3.5-flash
# Imagen (Nano Banana): gemini-3.1-flash-image | gemini-3-pro-image
# Video (Veo 3.1): veo-3.1-lite-generate-001 | veo-3.1-generate-001 | veo-3.1-fast-generate-001
LLM_MODEL=gemini-3.1-pro-preview
IMAGE_MODEL=gemini-3.1-flash-image
VIDEO_MODEL=veo-3.1-lite-generate-001

# Cantidad de variantes por imagen (1-4). Solo aplica a imagenes.
IMAGE_VARIANTS=1

# --- Almacenamiento local (NADA de servicios externos) ---
# Carpeta donde quedan imagenes/clips/manifest por proyecto.
OUTPUT_DIR=./output
# Estado de proyectos y jobs (JSON local).
DATA_DIR=./data

# --- Pipeline (opcional) ---
PIPELINE_CONCURRENCY=2
PIPELINE_MAX_ATTEMPTS=3
PIPELINE_BACKOFF_MS=1500
VEO_POLL_INTERVAL_MS=10000
VEO_POLL_TIMEOUT_MS=600000
PIPELINE_MAX_LOG=500

# --- Precios para la estimacion en la UI (opcional, solo informativo) ---
PRICE_IMAGE_USD=0.04
PRICE_VIDEO_PER_SEC_USD=0.5
PRICE_LLM_CALL_USD=0.02
